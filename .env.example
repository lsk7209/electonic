# EIA public data
EIA_API_KEY=

# Turso / libSQL
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Cron guard for /api/cron/eia-sync
CRON_SECRET=change-me

# Public site URL used in metadata, sitemap, and JSON-LD
NEXT_PUBLIC_SITE_URL=https://wattbenchs.com

# Optional AdSense ads.txt route. Example format: pub-1234567890123456
ADSENSE_PUBLISHER_ID=

# Optional GSC automation overrides. Defaults use D:\env on local Windows.
GSC_CLIENT_FILE=
GSC_TOKEN_FILE=
